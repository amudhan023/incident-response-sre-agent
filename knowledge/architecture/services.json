{
  "services": [
    {
      "name": "api-gateway",
      "description": "Central API gateway. Routes all external traffic to internal microservices. Handles TLS termination, rate limiting, authentication, and request routing.",
      "team": "platform-team",
      "criticality": "P0",
      "language": "Go",
      "sla": {"p99_latency_ms": 200, "error_rate_percent": 0.5, "availability": 99.99},
      "dependencies_upstream": [],
      "dependencies_downstream": ["payment-service", "order-service", "user-service"],
      "typical_metrics": {
        "request_rate_rps": 150,
        "error_rate_percent": 0.3,
        "latency_p99_ms": 120,
        "cpu_percent": 30,
        "memory_percent": 40
      },
      "common_failure_modes": ["TLS certificate expiry", "Upstream service timeout", "CPU saturation from RegEx", "OOM from WebSocket accumulation"],
      "on_call": "platform-oncall",
      "runbooks": ["high-latency-api", "cpu-saturation", "error-rate-spike"]
    },
    {
      "name": "payment-service",
      "description": "Handles all payment processing. Integrates with external banking APIs. Manages transaction lifecycle, refunds, and payment state machine.",
      "team": "payments-team",
      "criticality": "P0",
      "language": "Java (Spring Boot)",
      "sla": {"p99_latency_ms": 500, "error_rate_percent": 0.1, "availability": 99.99},
      "dependencies_upstream": ["api-gateway", "order-service"],
      "dependencies_downstream": ["postgres", "redis", "banking-api-external"],
      "typical_metrics": {
        "request_rate_rps": 80,
        "error_rate_percent": 0.1,
        "latency_p99_ms": 380,
        "cpu_percent": 22,
        "memory_percent": 65,
        "db_connections": 30
      },
      "common_failure_modes": ["DB connection exhaustion", "Banking API slowness", "JVM GC pauses", "Connection leaks", "High latency during deployments"],
      "on_call": "payments-oncall",
      "runbooks": ["high-latency-api", "database-connection-exhaustion", "deployment-rollback", "cpu-saturation"]
    },
    {
      "name": "order-service",
      "description": "Core order management. Creates, updates, and tracks orders through fulfillment lifecycle. Publishes order events to Kafka for downstream processing.",
