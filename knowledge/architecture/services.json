      "common_failure_modes": ["Kafka consumer lag from slow inventory calls", "Payment service timeout cascade", "Order processor NullPointerException"],
      "on_call": "commerce-oncall",
      "runbooks": ["kafka-consumer-lag", "error-rate-spike", "high-latency-api"]
    },
    {
