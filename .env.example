# ── REQUIRED ──────────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── OPTIONAL (defaults work for local demo) ───────────────────────────────────
POSTGRES_PASSWORD=sre_password

# Email recipients (comma-separated, all go to Mailhog locally)
EMAIL_RECIPIENTS=oncall@company.com,team@company.com

# Failure injection timing (seconds)
FAILURE_INTERVAL_MIN_SECONDS=300
FAILURE_INTERVAL_MAX_SECONDS=600
INITIAL_QUIET_PERIOD_SECONDS=60

# Anomaly detection sensitivity (higher = fewer alerts)
SIGMA_THRESHOLD=2.5
